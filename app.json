{
  "expo": {
    "name": "FieldWorker",
    "slug": "fieldworker-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fieldworker",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1C1E"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "FieldWorker needs camera access to capture site photos and signatures.",
        "NSPhotoLibraryUsageDescription": "FieldWorker needs photo library access to attach site photos.",
        "NSPhotoLibraryAddUsageDescription": "FieldWorker needs permission to save photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.shashankj02.fieldworkermobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1C1E"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FieldWorker to access your photos for site documentation.",
          "cameraPermission": "Allow FieldWorker to access your camera for site photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FieldWorker to access your camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f39e81fc-3f4c-4c8d-ae41-cfaac78e5c03"
      }
    }
  }
}
